{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pum_dependency.schema.json",
  "title": "PumDependency",
  "description": "Read-shape for `pum_dependency` from the Dataverse Web API (lookups as `_<name>_value`). Machine-readable contract for runtime drift-detection in the shipped app.",
  "x-dataverse": {
    "table": "pum_dependency",
    "env": "https://esben.crm.dynamics.com",
    "generated": "2026-06-16",
    "regenerate": "uv run python cli.py gen-schema pum_dependency"
  },
  "type": "object",
  "properties": {
    "pum_name": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 500
    },
    "_ownerid_value": {
      "type": "string",
      "format": "uuid",
      "x-lookup": {
        "targets": [
          "systemuser",
          "team"
        ],
        "bind": "OwnerId"
      }
    },
    "pum_dependencyid": {
      "type": "string",
      "format": "uuid"
    },
    "pum_duedate": {
      "type": "string",
      "format": "date"
    },
    "_pum_from_value": {
      "type": "string",
      "format": "uuid",
      "x-lookup": {
        "targets": [
          "pum_idea",
          "pum_initiative",
          "pum_program"
        ],
        "bind": "pum_From"
      }
    },
    "_pum_to_value": {
      "type": "string",
      "format": "uuid",
      "x-lookup": {
        "targets": [
          "pum_idea",
          "pum_initiative",
          "pum_program"
        ],
        "bind": "pum_To"
      }
    },
    "statecode": {
      "type": "integer",
      "enum": [
        0,
        1
      ],
      "x-choices": {
        "0": "Active",
        "1": "Inactive"
      }
    },
    "_createdby_value": {
      "type": [
        "string",
        "null"
      ],
      "format": "uuid",
      "x-lookup": {
        "targets": [
          "systemuser"
        ],
        "bind": "CreatedBy"
      }
    },
    "createdon": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "_createdonbehalfby_value": {
      "type": [
        "string",
        "null"
      ],
      "format": "uuid",
      "x-lookup": {
        "targets": [
          "systemuser"
        ],
        "bind": "CreatedOnBehalfBy"
      }
    },
    "importsequencenumber": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": -2147483648,
      "maximum": 2147483647
    },
    "_modifiedby_value": {
      "type": [
        "string",
        "null"
      ],
      "format": "uuid",
      "x-lookup": {
        "targets": [
          "systemuser"
        ],
        "bind": "ModifiedBy"
      }
    },
    "modifiedon": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "_modifiedonbehalfby_value": {
      "type": [
        "string",
        "null"
      ],
      "format": "uuid",
      "x-lookup": {
        "targets": [
          "systemuser"
        ],
        "bind": "ModifiedOnBehalfBy"
      }
    },
    "overriddencreatedon": {
      "type": [
        "string",
        "null"
      ],
      "format": "date"
    },
    "_owningbusinessunit_value": {
      "type": [
        "string",
        "null"
      ],
      "format": "uuid",
      "x-lookup": {
        "targets": [
          "businessunit"
        ],
        "bind": "OwningBusinessUnit"
      }
    },
    "pum_category": {
      "type": [
        "integer",
        "null"
      ],
      "enum": [
        493840000,
        493840001,
        493840002,
        493840003,
        null
      ],
      "x-choices": {
        "493840000": "Resource-based",
        "493840001": "Schedule-based",
        "493840002": "Technical",
        "493840003": "Customer/Stakeholder"
      }
    },
    "pum_kpi": {
      "type": [
        "integer",
        "null"
      ],
      "enum": [
        493840001,
        100000001,
        100000002,
        100000003,
        100000005,
        100000004,
        null
      ],
      "x-choices": {
        "493840001": "⚪ Not Set",
        "100000001": "🟢 On Track",
        "100000002": "🟡 Needs Attention",
        "100000003": "🔴 Delayed with major issues",
        "100000005": "✅ Completed",
        "100000004": "⚪ Not Relevant"
      }
    },
    "pum_seeddata": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 100
    },
    "statuscode": {
      "type": [
        "integer",
        "null"
      ],
      "enum": [
        1,
        2,
        null
      ],
      "x-choices": {
        "1": "Active",
        "2": "Inactive"
      }
    },
    "timezoneruleversionnumber": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": -1,
      "maximum": 2147483647
    },
    "utcconversiontimezonecode": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": -1,
      "maximum": 2147483647
    },
    "versionnumber": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": -9223372036854775808,
      "maximum": 9223372036854775807
    }
  },
  "additionalProperties": true,
  "required": [
    "_ownerid_value",
    "_pum_from_value",
    "_pum_to_value",
    "pum_dependencyid",
    "pum_duedate",
    "statecode"
  ]
}
