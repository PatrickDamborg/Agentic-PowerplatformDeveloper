{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pum_scenario.schema.json",
  "title": "PumScenario",
  "description": "Read-shape for `pum_scenario` from the Dataverse Web API (lookups as `_<name>_value`). Machine-readable contract for runtime drift-detection in the shipped app.",
  "x-dataverse": {
    "table": "pum_scenario",
    "env": "https://esben.crm.dynamics.com",
    "generated": "2026-06-16",
    "regenerate": "uv run python cli.py gen-schema pum_scenario"
