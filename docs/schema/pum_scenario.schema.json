      "type": "string",
      "format": "uuid"
    },
    "statecode": {
      "type": "integer",
      "enum": [
        0,
        1
      ],
      "x-choices": {
        "0": "Active",
        "1": "Inactive"
      }
    },
    "_context_portfolio_value": {
      "type": [
        "string",
        "null"
      ],
      "format": "uuid",
      "x-lookup": {
        "targets": [
