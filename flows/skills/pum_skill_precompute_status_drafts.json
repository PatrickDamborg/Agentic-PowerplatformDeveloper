                  "type": "OpenApiConnection",
                  "runAfter": {
                    "Agg_Actuals": [
                      "Succeeded"
                    ]
                  },
                  "inputs": {
                    "host": {
                      "connectionName": "shared_commondataserviceforapps",
                      "operationId": "ListRecords",
                      "apiId": "/providers/Microsoft.PowerApps/apis/shared_commondataserviceforapps"
                    },
                    "parameters": {
                      "entityName": "pum_pf_powerfinancialsdatas",
                      "fetchXml": "<fetch aggregate=\"true\"><entity name=\"pum_pf_powerfinancialsdata\"><attribute name=\"pum_pf_valuedec\" alias=\"forecastsum\" aggregate=\"sum\" /><filter type=\"and\"><condition attribute=\"pum_pf_initiative\" operator=\"eq\" value=\"@{item()?['pum_initiativeid']}\" /><condition attribute=\"pum_pf_costtypedef\" operator=\"eq\" value=\"3\" /></filter></entity></fetch>"
