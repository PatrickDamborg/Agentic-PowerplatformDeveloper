                    ]
                  },
                  "inputs": "@filter(createArray(if(equals(outputs('Compute_Financials_Rating')?['ratingInt'], 493840000), 'No financial data found for this initiative \u2014 Financials rated N/A.', null), if(equals(outputs('Compute_Resources_Rating')?['ratingInt'], 493840000), 'No resource plan data found for this initiative \u2014 Resources rated N/A.', null), if(and(equals(outputs('Compute_Scope_Rating')?['openRiskCount'], 0), equals(outputs('Compute_Scope_Rating')?['openChangeRequestCount'], 0)), 'Scope rated Green based on absence of open risks/change requests, not a confirmed clean status.', null)), not(equals(item(), null)))"
                },
                "Compose_Cache_Payload": {
                  "type": "Compose",
                  "runAfter": {
                    "Compute_Data_Gaps": [
                      "Succeeded"
                    ]
                  },
                  "inputs": {
                    "initiativeId": "@item()?['pum_initiativeid']",
                    "initiativeName": "@outputs('Get_Initiative')?['body/pum_name']",
                    "currentPhase": "@outputs('Get_Initiative')?['body/pum_currentstagetextfield']",
                    "computedOn": "@utcNow()",
                    "source": "precomputed",
                    "timeline": {
                      "rating": "@outputs('Rating_Labels')?[string(outputs('Compute_Timeline_Rating')?['ratingInt'])]",
                      "ratingInt": "@outputs('Compute_Timeline_Rating')?['ratingInt']",
                      "incompleteCount": "@outputs('Compute_Timeline_Rating')?['incompleteCount']",
                      "overdueCount": "@outputs('Compute_Timeline_Rating')?['overdueCount']",
                      "worstOverdueDays": "@outputs('Compute_Timeline_Rating')?['worstOverdueDays']",
                      "nextMilestoneDate": "@outputs('Compute_Timeline_Rating')?['nextMilestoneDate']"
                    },
                    "financials": {
                      "rating": "@outputs('Rating_Labels')?[string(outputs('Compute_Financials_Rating')?['ratingInt'])]",
                      "ratingInt": "@outputs('Compute_Financials_Rating')?['ratingInt']",
                      "hasData": "@outputs('Compute_Financials_Rating')?['hasData']",
                      "budget": "@outputs('Compute_Financials_Rating')?['budget']",
                      "actuals": "@outputs('Compute_Financials_Rating')?['actuals']",
                      "forecast": "@outputs('Compute_Financials_Rating')?['forecast']",
                      "variancePct": "@outputs('Compute_Financials_Rating')?['variancePct']"
                    },
                    "scope": {
                      "rating": "@outputs('Rating_Labels')?[string(outputs('Compute_Scope_Rating')?['ratingInt'])]",
                      "ratingInt": "@outputs('Compute_Scope_Rating')?['ratingInt']",
                      "openRiskCount": "@outputs('Compute_Scope_Rating')?['openRiskCount']",
                      "highRiskCount": "@outputs('Compute_Scope_Rating')?['highRiskCount']",
                      "openChangeRequestCount": "@outputs('Compute_Scope_Rating')?['openChangeRequestCount']",
                      "topRisks": "@body('Select_Top_Risks')"
                    },
                    "quality": {
                      "rating": "@outputs('Rating_Labels')?[string(outputs('Compute_Quality_Rating')?['ratingInt'])]",
                      "ratingInt": "@outputs('Compute_Quality_Rating')?['ratingInt']",
                      "qualityLessonCount": "@outputs('Compute_Quality_Rating')?['qualityLessonCount']",
                      "qualityRiskCount": "@outputs('Compute_Quality_Rating')?['qualityRiskCount']"
                    },
                    "resources": {
                      "rating": "@outputs('Rating_Labels')?[string(outputs('Compute_Resources_Rating')?['ratingInt'])]",
                      "ratingInt": "@outputs('Compute_Resources_Rating')?['ratingInt']",
                      "hasData": "@outputs('Compute_Resources_Rating')?['hasData']",
                      "proposedHours": "@outputs('Compute_Resources_Rating')?['proposedHours']",
                      "committedHours": "@outputs('Compute_Resources_Rating')?['committedHours']",
                      "gapHours": "@outputs('Compute_Resources_Rating')?['gapHours']",
                      "gapPct": "@outputs('Compute_Resources_Rating')?['gapPct']"
                    },
                    "overall": {
                      "rating": "@outputs('Rating_Labels')?[string(outputs('Compute_Overall_Rating')?['ratingInt'])]",
                      "ratingInt": "@outputs('Compute_Overall_Rating')?['ratingInt']"
                    },
                    "trend": {
                      "hasPriorReport": "@outputs('Compute_Trend')?['hasPriorReport']",
                      "priorReportDate": "@outputs('Compute_Trend')?['priorReportDate']",
                      "priorSummaryRating": "@if(equals(outputs('Compute_Trend')?['priorSummaryRatingInt'], null), null, outputs('Rating_Labels')?[string(outputs('Compute_Trend')?['priorSummaryRatingInt'])])",
                      "priorComment": "@outputs('Compute_Trend')?['priorComment']"
                    },
                    "dataGaps": "@outputs('Compute_Data_Gaps')"
                  }
                },
                "Check_Existing_Cache_Row": {
                  "type": "OpenApiConnection",
                  "runAfter": {
                    "Compose_Cache_Payload": [
                      "Succeeded"
                    ]
                  },
                  "inputs": {
                    "host": {
                      "connectionName": "shared_commondataserviceforapps",
                      "operationId": "ListRecords",
                      "apiId": "/providers/Microsoft.PowerApps/apis/shared_commondataserviceforapps"
                    },
                    "parameters": {
                      "entityName": "pum_statusdraftcaches",
                      "$filter": "_pum_initiative_value eq @{item()?['pum_initiativeid']}",
                      "$select": "pum_statusdraftcacheid",
                      "$top": 1
                    },
                    "authentication": "@parameters('$authentication')"
                  }
                },
                "Upsert_Cache_Row": {
                  "type": "If",
                  "runAfter": {
                    "Check_Existing_Cache_Row": [
                      "Succeeded"
                    ]
                  },
                  "expression": {
                    "equals": [
                      "@length(body('Check_Existing_Cache_Row')?['value'])",
                      0
                    ]
                  },
                  "actions": {
                    "Create_Cache_Row": {
                      "type": "OpenApiConnection",
                      "runAfter": {},
                      "inputs": {
                        "host": {
                          "connectionName": "shared_commondataserviceforapps",
                          "operationId": "CreateRecord",
                          "apiId": "/providers/Microsoft.PowerApps/apis/shared_commondataserviceforapps"
                        },
                        "parameters": {
                          "entityName": "pum_statusdraftcaches",
                          "item/pum_name": "@{item()?['pum_name']} - Cache @{formatDateTime(utcNow(), 'yyyy-MM-dd')}",
                          "item/pum_Initiative@odata.bind": "/pum_initiatives(@{item()?['pum_initiativeid']})",
                          "item/pum_computedon": "@utcNow()",
                          "item/pum_payload": "@{string(outputs('Compose_Cache_Payload'))}",
                          "item/pum_timelinerating": "@outputs('Compute_Timeline_Rating')?['ratingInt']",
                          "item/pum_financialsrating": "@outputs('Compute_Financials_Rating')?['ratingInt']",
                          "item/pum_scoperating": "@outputs('Compute_Scope_Rating')?['ratingInt']",
                          "item/pum_qualityrating": "@outputs('Compute_Quality_Rating')?['ratingInt']",
                          "item/pum_resourcesrating": "@outputs('Compute_Resources_Rating')?['ratingInt']",
                          "item/pum_overallrating": "@outputs('Compute_Overall_Rating')?['ratingInt']"
                        },
                        "authentication": "@parameters('$authentication')"
                      }
                    }
                  },
                  "else": {
                    "actions": {
                      "Update_Cache_Row": {
                        "type": "OpenApiConnection",
                        "runAfter": {},
                        "inputs": {
                          "host": {
                            "connectionName": "shared_commondataserviceforapps",
                            "operationId": "UpdateRecord",
                            "apiId": "/providers/Microsoft.PowerApps/apis/shared_commondataserviceforapps"
                          },
                          "parameters": {
                            "entityName": "pum_statusdraftcaches",
                            "recordId": "@first(body('Check_Existing_Cache_Row')?['value'])?['pum_statusdraftcacheid']",
                            "item/pum_name": "@{item()?['pum_name']} - Cache @{formatDateTime(utcNow(), 'yyyy-MM-dd')}",
                            "item/pum_Initiative@odata.bind": "/pum_initiatives(@{item()?['pum_initiativeid']})",
                            "item/pum_computedon": "@utcNow()",
                            "item/pum_payload": "@{string(outputs('Compose_Cache_Payload'))}",
                            "item/pum_timelinerating": "@outputs('Compute_Timeline_Rating')?['ratingInt']",
                            "item/pum_financialsrating": "@outputs('Compute_Financials_Rating')?['ratingInt']",
                            "item/pum_scoperating": "@outputs('Compute_Scope_Rating')?['ratingInt']",
                            "item/pum_qualityrating": "@outputs('Compute_Quality_Rating')?['ratingInt']",
                            "item/pum_resourcesrating": "@outputs('Compute_Resources_Rating')?['ratingInt']",
                            "item/pum_overallrating": "@outputs('Compute_Overall_Rating')?['ratingInt']"
                          },
                          "authentication": "@parameters('$authentication')"
                        }
                      }
                    }
                  }
                }
              },
              "runtimeConfiguration": {
                "concurrency": {
                  "repetitions": 5
                }
              }
            }
          }
        },
        "Catch_Scope": {
          "type": "Scope",
          "runAfter": {
            "Try_Scope": [
              "Failed",
              "TimedOut"
            ]
          },
          "actions": {
            "Compose_Error_Details": {
              "type": "Compose",
              "runAfter": {},
              "inputs": {
                "flowName": "@workflow()?['tags']['flowDisplayName']",
                "runId": "@workflow()?['run']['name']",
                "errorResult": "@result('Try_Scope')",
                "timestamp": "@utcNow()"
              }
            },
            "Log_Error_Row": {
              "type": "OpenApiConnection",
              "runAfter": {
                "Compose_Error_Details": [
                  "Succeeded"
                ]
              },
              "inputs": {
                "host": {
                  "connectionName": "shared_commondataserviceforapps",
                  "operationId": "CreateRecord",
                  "apiId": "/providers/Microsoft.PowerApps/apis/shared_commondataserviceforapps"
                },
                "parameters": {
                  "entityName": "pum_activitylogs",
                  "item/pum_category": "CopilotSkill",
                  "item/pum_details": "@{string(outputs('Compose_Error_Details'))}"
                },
                "authentication": "@parameters('$authentication')"
              }
            }
          }
        }
      }
    },
    "templateName": ""
  },
  "schemaVersion": "1.0.0.0",
  "_comment": "Phase 2 pre-compute: runs weekly (Monday 06:30 UTC) over all active initiatives, applying the SAME fetch+compute logic as pum_skill_fetch_status_data (duplicated inline per initiative in the loop \u2014 accepted for the demo since the fetch flow's Copilot-Studio-only trigger type cannot be invoked as a child flow from a Recurrence-triggered flow). Upserts one row per initiative into pum_statusdraftcaches. Writes to a cache table only \u2014 NEVER to pum_statusreportings; the approval-gated save stays exclusively in the chat flow (status-report-drafter skill). Concurrency capped at 5 concurrent initiatives via runtimeConfiguration.concurrency. Not latency-critical \u2014 no express mode, no 2-minute constraint (this is a classic Recurrence trigger, not an agent-triggered flow). VERIFY the FetchXml aggregate alias addressing (see pum_skill_fetch_status_data.json's _comment) and the recurrence schedule/timezone via a manual test run before relying on it."
}
