                    "ratingInt": "@if(equals(coalesce(first(outputs('Agg_Overdue_Tasks')?['body/value'])?['overduecount'], 0), 0), 493840003, if(or(greater(div(sub(ticks(utcNow()), ticks(first(outputs('Agg_Overdue_Tasks')?['body/value'])?['worstenddate'])), 864000000000), 30), greater(mul(div(float(coalesce(first(outputs('Agg_Overdue_Tasks')?['body/value'])?['overduecount'], 0)), float(max(coalesce(first(outputs('Agg_Incomplete_Tasks')?['body/value'])?['incompletecount'], 0), 1))), 100), 25)), 493840001, 493840002))"
                  }
                },
                "List_Open_Risks": {
